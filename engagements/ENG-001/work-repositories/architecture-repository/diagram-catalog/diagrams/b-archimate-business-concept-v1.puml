' ---
' artifact-id: b-archimate-business-concept-v1
' artifact-type: diagram
' name: "Business Architecture — Business Concept Map"
' diagram-type: archimate-business
' version: 0.1.0
' status: draft
' phase-produced: B
' owner-agent: SA
' engagement: ENG-001
' domain: core-platform
' purpose: >
'   Business concept map showing the six key business objects (BOB) that persist
'   across value-stream stages, the business events (BEV) that trigger process
'   transitions, and the processes (BPR) that access or generate each object.
'   Also shows cross-layer BOB↔DOB associations. Answers: "what are the durable
'   information concepts in this system and what triggers state changes?"
'   Per diagram-conventions §11.9.3: 6 BOB entities — diagram is optional but
'   included to make cross-layer concept mapping explicit.
' entity-ids-used:
'   - BOB-001
'   - BOB-002
'   - BOB-003
'   - BOB-004
'   - BOB-005
'   - BOB-006
'   - BEV-001
'   - BEV-002
'   - BEV-003
'   - BEV-004
'   - BEV-005
'   - BEV-006
'   - BEV-007
'   - BEV-008
'   - BPR-001
'   - BPR-002
'   - BPR-003
'   - BPR-004
'   - BPR-005
'   - BIA-001
'   - BPR-007
'   - BPR-008
' connection-ids-used:
'   - BEV-001---BPR-001
'   - BEV-002---BPR-001
'   - BEV-002---BIA-001
'   - BEV-003---BPR-001
'   - BEV-004---BPR-003
'   - BEV-005---BPR-005
'   - BEV-006---BIA-001
'   - BEV-007---BPR-008
'   - BPR-001---BOB-002
'   - BPR-002---BOB-001
'   - BPR-002---BOB-002
'   - BPR-002---BOB-006
'   - BPR-003---BOB-003
'   - BPR-004---BOB-004
'   - BPR-005---BOB-005
' ---
@startuml b-archimate-business-concept-v1
!include ../_macros.puml
!include ../_archimate-stereotypes.puml

skinparam groupInheritance 1
skinparam nodesep 40
skinparam ranksep 55
skinparam padding 8

' ---------------------------------------------------------------------------
' Business Events (triggers — left side)
' ---------------------------------------------------------------------------
rectangle "Business Events (Triggers)" <<BusinessGrouping>> as GRP_EVTS {
  DECL_BEV_001
  DECL_BEV_002
  DECL_BEV_003
  DECL_BEV_004
  DECL_BEV_005
  DECL_BEV_006
  DECL_BEV_007
  DECL_BEV_008
}

' ---------------------------------------------------------------------------
' Processes (center — showing which objects they access)
' ---------------------------------------------------------------------------
rectangle "Processes" <<BusinessGrouping>> as GRP_PROCS {
  DECL_BPR_001
  DECL_BPR_002
  DECL_BPR_003
  DECL_BPR_004
  DECL_BPR_005
  DECL_BIA_001
  DECL_BPR_007
  DECL_BPR_008
}

' ---------------------------------------------------------------------------
' Business Objects (right side — durable concepts)
' ---------------------------------------------------------------------------
rectangle "Business Objects" <<BusinessGrouping>> as GRP_OBJ {
  DECL_BOB_001
  DECL_BOB_002
  DECL_BOB_003
  DECL_BOB_004
  DECL_BOB_005
  DECL_BOB_006
}

' ---------------------------------------------------------------------------
' Event → Process triggering
' ---------------------------------------------------------------------------
BEV_001 -[#B8860B]-> BPR_001 : <<triggering>>
BEV_002 -[#B8860B]-> BPR_001 : <<triggering>>
BEV_003 -[#B8860B]-> BPR_001 : <<triggering>>
BEV_004 -[#B8860B]-> BPR_003 : <<triggering>>
BEV_005 -[#B8860B]-> BPR_005 : <<triggering>>
BEV_006 -[#B8860B]-> BIA_001 : <<triggering>>
BEV_007 -[#B8860B]-> BPR_008 : <<triggering>>

' ---------------------------------------------------------------------------
' Process → Object access
' ---------------------------------------------------------------------------
BPR_001 -[#808080]-> BOB_002 : <<access (write)>>
BPR_002 -[#808080]-> BOB_001 : <<access (write)>>
BPR_002 -[#808080]-> BOB_002 : <<access (read)>>
BPR_002 -[#808080]-> BOB_006 : <<access (r/w)>>
BPR_003 -[#808080]-> BOB_003 : <<access (r/w)>>
BPR_004 -[#808080]-> BOB_004 : <<access (write)>>
BPR_005 -[#808080]-> BOB_005 : <<access (r/w)>>

note as N1
  Concept map: BEV (triggers) → BPR (processes) → BOB (objects).
  BEV-008 (Engagement Completed) terminates the BEV-002 loop.
  BOB↔DOB cross-layer mappings:
    BOB-001 ↔ DOB-013 (ArtifactRecord)
    BOB-002 ↔ DOB-009 (WorkflowState)
    BOB-003 ↔ DOB-004 (ClarificationRequest)
    BOB-004 ↔ DOB-007 (GateOutcome)
    BOB-005 ↔ DOB-005 (AlgedonicSignal)
    BOB-006 ↔ DOB-003 (LearningEntry)
  See association connections in connections/archimate/association/.
end note

@enduml
