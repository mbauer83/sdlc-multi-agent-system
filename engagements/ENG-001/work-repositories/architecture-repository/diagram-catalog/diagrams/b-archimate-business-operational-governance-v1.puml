@startuml b-archimate-business-operational-governance-v1
!include ../_macros.puml
!include ../_archimate-stereotypes.puml

skinparam groupInheritance 1
skinparam nodesep 35
skinparam ranksep 50
skinparam padding 8

' ---------------------------------------------------------------------------
' Triggering Events (initiation and termination)
' ---------------------------------------------------------------------------
rectangle "Triggering Events" <<BusinessGrouping>> as GRP_EVTS {
  DECL_BEV_001
  DECL_BEV_002
  DECL_BEV_003
  DECL_BEV_006
  DECL_BEV_008
}

' ---------------------------------------------------------------------------
' Governance Processes
' ---------------------------------------------------------------------------
rectangle "Governance Processes" <<BusinessGrouping>> as GRP_PROCS {
  DECL_BPR_001
  DECL_BPR_004
  DECL_BPR_006
}

' ---------------------------------------------------------------------------
' Sprint Review Collaborative Interaction
' ---------------------------------------------------------------------------
rectangle "Sprint Review Interaction" <<BusinessGrouping>> as GRP_IA {
  DECL_BIA_001
  DECL_BCO_002
}

' ---------------------------------------------------------------------------
' Roles / Actors
' ---------------------------------------------------------------------------
rectangle "Roles" <<BusinessGrouping>> as GRP_ROLES {
  DECL_ACT_001
  DECL_ACT_002
  DECL_ACT_010
}

' ---------------------------------------------------------------------------
' Business Objects (key managed objects in this cluster)
' ---------------------------------------------------------------------------
rectangle "Key Objects" <<BusinessGrouping>> as GRP_OBJ {
  DECL_BOB_002
  DECL_BOB_004
}

' ---------------------------------------------------------------------------
' Business Services (outputs of governance cluster)
' ---------------------------------------------------------------------------
rectangle "Delivered Services" <<BusinessGrouping>> as GRP_SVCS {
  DECL_BSV_003
  DECL_BSV_009
}

' ---------------------------------------------------------------------------
' Event → Process triggering
' ---------------------------------------------------------------------------
BEV_001 -[#B8860B]-> BPR_001 : <<triggering>>
BEV_002 -[#B8860B]-> BPR_001 : <<triggering>>
BEV_002 -[#B8860B]-> BIA_001 : <<triggering>>
BEV_003 -[#B8860B]-> BPR_001 : <<triggering>>
BEV_006 -[#B8860B]-> BPR_006 : <<triggering>>

' ---------------------------------------------------------------------------
' Role / Collaboration assignments
' ---------------------------------------------------------------------------
ACT_002 -[#B8860B]-> BPR_001 : <<assignment>>
ACT_002 -[#B8860B]-> BPR_004 : <<assignment>>
ACT_002 -[#B8860B]-> BPR_006 : <<assignment>>
ACT_010 -[#B8860B]-> BPR_004 : <<assignment>>
ACT_001 -[#B8860B]-> BPR_006 : <<assignment>>
ACT_001 -[#B8860B]-> BCO_002 : <<assignment>>
ACT_002 -[#B8860B]-> BCO_002 : <<assignment>>
BCO_002 -[#B8860B]-> BIA_001 : <<assignment>>

' ---------------------------------------------------------------------------
' Process / Interaction → Service realization
' ---------------------------------------------------------------------------
BPR_001 ..[#B8860B].>> BSV_003 : <<realization>>
BPR_004 ..[#B8860B].>> BSV_003 : <<realization>>
BPR_006 ..[#B8860B].>> BSV_009 : <<realization>>
BIA_001 ..[#B8860B].>> BSV_009 : <<realization>>

' ---------------------------------------------------------------------------
' Process → Object access (key objects produced/consumed)
' ---------------------------------------------------------------------------
BPR_001 -[#808080]-> BOB_002 : <<access (write)>>
BPR_004 -[#808080]-> BOB_004 : <<access (write)>>

note as N1
  Governance cluster: sprint lifecycle + gate + review.
  BEV-008 (Engagement Completed) terminates BEV-002 loop —
  when recorded, Sprint Planning (BPR-001) does NOT re-fire.
  BIA-001 + BCO-002: structured PM+User sprint review sequence.
  See operational-execution diagram for skill/CQ/knowledge cluster.
end note

@enduml
