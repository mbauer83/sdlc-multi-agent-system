@startuml phase-c-activity-cq-lifecycle-v1
title Phase C Activity — CQ Lifecycle

skinparam activity {
  BackgroundColor AliceBlue
  BorderColor SteelBlue
  DiamondBackgroundColor LightYellow
  DiamondBorderColor DarkGoldenrod
  ArrowColor SteelBlue
  FontSize 11
}
skinparam swimlane {
  BorderColor CadetBlue
  TitleFontStyle bold
}

|Specialist Agents|
start
:Detect missing information
during BPR-202;
:Raise CQ and enter
BPR-003 lifecycle;

|PM Agent|
:BPR-301 Route CQ to user
(single or batched);

|User|
:BPR-302 Review CQ and
submit answer;

|PM Agent|
:BPR-303 Integrate answer
and route resume;

|Specialist Agents|
:Resume suspended task with
answer in context;
stop

@enduml
