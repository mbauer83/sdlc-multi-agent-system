' domain: core-platform
' purpose: >
'   Business-process activity view for CQ raise/batch/answer/resume flow.
'   Captures BPR-003 decomposition and user-facing suspension/resume semantics
'   without introducing application-layer sequence detail.
' entity-ids-used:
'   - ACT-003
'   - ACT-002
'   - ACT-001
'   - BPR-003
'   - BPR-301
'   - BPR-302
