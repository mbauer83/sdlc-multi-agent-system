@startuml b-archimate-business-structural-v1
!include ../_macros.puml
!include ../_archimate-stereotypes.puml
title Business Architecture — Structural Viewpoint

skinparam groupInheritance 1
skinparam nodesep 30
skinparam ranksep 50
skinparam padding 8

' ---------------------------------------------------------------------------
' Capabilities (Strategy layer — realized by functions)
' ---------------------------------------------------------------------------
rectangle "Capabilities" <<StrategyGrouping>> as CAPS {
  DECL_CAP_001
  DECL_CAP_002
  DECL_CAP_003
  DECL_CAP_004
  DECL_CAP_005
  DECL_CAP_006
}

' ---------------------------------------------------------------------------
' BFN-001 — Engagement Governance  (PM owns)
' ---------------------------------------------------------------------------
rectangle "Engagement Governance" <<BusinessGrouping>> as FN_GOV {
  DECL_BFN_001
  DECL_ACT_002
}

' ---------------------------------------------------------------------------
' BFN-002 — Specialist Execution  (all agents collectively)
' ---------------------------------------------------------------------------
rectangle "Specialist Execution" <<BusinessGrouping>> as FN_EXEC {
  DECL_BFN_002
  DECL_BCO_001
}

' ---------------------------------------------------------------------------
' BFN-003 — Human Collaboration  (PM + User)
' ---------------------------------------------------------------------------
rectangle "Human Collaboration" <<BusinessGrouping>> as FN_HUMAN {
  DECL_BFN_003
  DECL_ACT_001
}

' ---------------------------------------------------------------------------
' BFN-004 — Safety & Compliance  (CSCO owns)
' ---------------------------------------------------------------------------
rectangle "Safety & Compliance" <<BusinessGrouping>> as FN_SAFE {
  DECL_BFN_004
  DECL_ACT_010
}

' ---------------------------------------------------------------------------
' BFN-005 — Knowledge Management  (SA + Architecture Board)
' ---------------------------------------------------------------------------
rectangle "Knowledge Management" <<BusinessGrouping>> as FN_KNOW {
  DECL_BFN_005
  DECL_ACT_003
}

' ---------------------------------------------------------------------------
' Business Services (external view — delivered to stakeholders)
' ---------------------------------------------------------------------------
rectangle "Business Services" <<BusinessGrouping>> as SVCS {
  DECL_BSV_001
  DECL_BSV_002
  DECL_BSV_003
  DECL_BSV_004
  DECL_BSV_005
  DECL_BSV_006
  DECL_BSV_007
  DECL_BSV_008
  DECL_BSV_009
}

' ---------------------------------------------------------------------------
' Role assignments (active structure → function)
' ---------------------------------------------------------------------------
ACT_002 -[#B8860B]-> BFN_001 : <<assignment>>
BCO_001 -[#B8860B]-> BFN_002 : <<assignment>>
ACT_001 -[#B8860B]-> BFN_003 : <<assignment>>
ACT_002 -[#B8860B]-> BFN_003 : <<assignment>>
ACT_010 -[#B8860B]-> BFN_004 : <<assignment>>
ACT_003 -[#B8860B]-> BFN_005 : <<assignment>>
BCO_001 -[#B8860B]-> BFN_005 : <<assignment>>

' ---------------------------------------------------------------------------
' Function realizes Capability (cross-layer, steel blue)
' ---------------------------------------------------------------------------
BFN_001 ..[#4682B4].>> CAP_003 : <<realization>>
BFN_002 ..[#4682B4].>> CAP_001 : <<realization>>
BFN_002 ..[#4682B4].>> CAP_002 : <<realization>>
BFN_003 ..[#4682B4].>> CAP_005 : <<realization>>
BFN_005 ..[#4682B4].>> CAP_004 : <<realization>>
BFN_005 ..[#4682B4].>> CAP_006 : <<realization>>

' ---------------------------------------------------------------------------
' Function realizes Service (business layer, dark goldenrod)
' ---------------------------------------------------------------------------
BFN_001 ..[#B8860B].>> BSV_003 : <<realization>>
BFN_001 ..[#B8860B].>> BSV_009 : <<realization>>
BFN_002 ..[#B8860B].>> BSV_001 : <<realization>>
BFN_002 ..[#B8860B].>> BSV_002 : <<realization>>
BFN_002 ..[#B8860B].>> BSV_005 : <<realization>>
BFN_002 ..[#B8860B].>> BSV_006 : <<realization>>
BFN_002 ..[#B8860B].>> BSV_007 : <<realization>>
BFN_002 ..[#B8860B].>> BSV_008 : <<realization>>
BFN_003 ..[#B8860B].>> BSV_009 : <<realization>>
BFN_004 ..[#B8860B].>> BSV_004 : <<realization>>
BFN_005 ..[#B8860B].>> BSV_001 : <<realization>>
BFN_005 ..[#B8860B].>> BSV_002 : <<realization>>

note as N1
  Structural viewpoint: stable organizational functions
  and their assigned roles/collaborations. Processes,
  events, and objects are in the operational diagrams.
  BFN-002 also realizes BSV-001/BSV-002 through
  Phase B/C skills; BFN-005 additionally for rev-arch.
  Color: dark goldenrod = business-layer; steel blue = strategy-layer.
end note

@enduml
