' ---------------------------------------------------------------------------
' Cross-layer boundary: Business Services realized by application services below.
' Declared outside application groups — these elements live in the business layer
' (phase-b-archimate-business-v1) and appear here only as realization targets.
' ---------------------------------------------------------------------------
rectangle "Business Architecture Service" <<BusinessService>> as BSV_001
rectangle "App & Technology Architecture Service" <<BusinessService>> as BSV_002
rectangle "Project Coordination Service" <<BusinessService>> as BSV_003
rectangle "User Decisions Service" <<BusinessService>> as BSV_009

' Cross-layer boundary: Application Services that realize the business services above.
' ASV-001 groups APP-004+APP-005+APP-006 (agent invocation stack).
' ASV-003 and ASV-004 handle sprint-review and CQ user-decision flows.
DECL_ASV_001
DECL_ASV_003
DECL_ASV_004

' Cross-layer boundary: Human actor served by the dashboard.
rectangle "User" <<BusinessActor>> as ACT_001

' ---------------------------------------------------------------------------
' State & Storage  →  src/events/ + src/common/
' ---------------------------------------------------------------------------
rectangle "State & Storage\nsrc/events/ + src/common/" <<ApplicationGrouping>> as GRP_STATE {
  DECL_APP_001
  DECL_APP_002
  DECL_APP_003
}

' ---------------------------------------------------------------------------
' Agent Runtime  →  src/agents/ infrastructure
' ---------------------------------------------------------------------------
rectangle "Agent Runtime\nsrc/agents/ (infrastructure)" <<ApplicationGrouping>> as GRP_RUNTIME {
  DECL_APP_004
  DECL_APP_005
  DECL_APP_006
  DECL_AIF_002
  DECL_AIF_004
  DECL_AIF_005
  DECL_AIF_006
}

' ---------------------------------------------------------------------------
' Agent Roster  →  src/agents/<role>.py
' ---------------------------------------------------------------------------
