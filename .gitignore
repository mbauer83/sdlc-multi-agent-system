# Virtual environments
.venv/
venv/
env/
ENV/
.env.bak

# Secrets and credentials — NEVER commit
.env
*.key
*.pem
secrets.yaml
secrets.json

# SQLite WAL and journal temporary files — only present while the DB is open.
# workflow.db itself IS git-tracked (it is the canonical event store).
# See framework/architecture-repository-design.md §4.2
engagements/**/workflow.db-journal
engagements/**/workflow.db-wal
engagements/**/workflow.db-shm

# Target project repository local clones — separate git repos, never committed here.
# Multi-repo engagements use target-repos/<repo-id>/; single-repo uses target-repos/default/
# Backward-compat: old engagements may use target-repo/ (singular) — also excluded.
# See framework/architecture-repository-design.md §2.4 and §3.4
engagements/**/target-repos/
engagements/**/target-repo/

# ENG-DEMO: ephemeral demo/test engagement — torn down and rebuilt on each run.
# Contents are regenerated by scripts/demo_setup.py; not a persistent artifact.
engagements/ENG-DEMO/
# Git worktrees created per agent/sprint for isolation (merged back at sprint close)
engagements/**/*-wt-*/

# Alembic
alembic.ini.bak

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
